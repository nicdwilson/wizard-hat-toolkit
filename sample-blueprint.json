{
	"version": "1.0",
	"name": "Sample WooCommerce Store Blueprint",
	"description": "A sample blueprint for setting up a basic WooCommerce store with essential plugins and configurations",
	"author": "Wizard Hat Toolkit",
	"created": "2024-01-15T10:00:00Z",
	"plugins": [
		{
			"name": "WooCommerce",
			"slug": "woocommerce",
			"version": "latest",
			"active": true,
			"source": "wordpress.org"
		},
		{
			"name": "WooCommerce Stripe Gateway",
			"slug": "woocommerce-gateway-stripe",
			"version": "latest",
			"active": true,
			"source": "wordpress.org"
		},
		{
			"name": "WooCommerce PayPal Payments",
			"slug": "woocommerce-paypal-payments",
			"version": "latest",
			"active": true,
			"source": "wordpress.org"
		},
		{
			"name": "WooCommerce Subscriptions",
			"slug": "woocommerce-subscriptions",
			"version": "latest",
			"active": false,
			"source": "premium"
		},
		{
			"name": "WooCommerce Memberships",
			"slug": "woocommerce-memberships",
			"version": "latest",
			"active": false,
			"source": "premium"
		}
	],
	"themes": [
		{
			"name": "Storefront",
			"slug": "storefront",
			"version": "latest",
			"active": true,
			"source": "wordpress.org"
		}
	],
	"settings": {
		"woocommerce": {
			"woocommerce_store_address": "123 Main Street",
			"woocommerce_store_address_2": "Suite 100",
			"woocommerce_store_city": "New York",
			"woocommerce_default_country": "US:NY",
			"woocommerce_store_postcode": "10001",
			"woocommerce_currency": "USD",
			"woocommerce_price_thousand_sep": ",",
			"woocommerce_price_decimal_sep": ".",
			"woocommerce_weight_unit": "lbs",
			"woocommerce_dimension_unit": "in",
			"woocommerce_calc_taxes": "yes",
			"woocommerce_enable_guest_checkout": "yes",
			"woocommerce_enable_checkout_login_reminder": "yes",
			"woocommerce_enable_signup_and_login_from_checkout": "yes",
			"woocommerce_enable_myaccount_registration": "yes",
			"woocommerce_registration_generate_username": "yes",
			"woocommerce_registration_generate_password": "yes"
		},
		"wordpress": {
			"blogname": "My WooCommerce Store",
			"blogdescription": "A sample WooCommerce store",
			"admin_email": "admin@example.com"
		},
		"custom": {
			"custom_store_setting": "custom_value"
		}
	}
}
